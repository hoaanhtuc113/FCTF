PRIVATE_KEY=replace_me
# Optional TLS certificate pair mounted from cert-manager secret gateway-tls.
# Leave empty for local plaintext development.
GATEWAY_TLS_CERT_FILE=
GATEWAY_TLS_KEY_FILE=
# Token-based HTTP limits (applies after token verification)
HTTP_RATE=300
HTTP_BURST=600
# Per-IP HTTP limiter to prevent token rotation attacks
# Increased default because many contestants may share a network
HTTP_IP_RATE=500
HTTP_IP_BURST=1000
HTTP_MAX_BODY_BYTES=10485760
# TCP connection attempt/throughput limits
TCP_RATE=10
TCP_BURST=30
TCP_COPY_BUF_BYTES=32768
# TCP auth timeout (seconds) - reduces time a connection can hold auth slot
TCP_AUTH_TIMEOUT_SECONDS=5
# Connection counter TTL (seconds) - limits how long a stale counter may persist
TCP_CONN_TTL_SECONDS=300
TCP_MAX_CONNS=4000
# Increased per-IP connection cap to better support LANed contestants
TCP_MAX_CONNS_PER_IP=1000
TCP_MAX_CONNS_PER_TOKEN=15
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fctf:gateway
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE=10
REDIS_FAIL_CLOSED=false
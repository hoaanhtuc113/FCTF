      "mode": "upsert",
      "preSQL":  ["SET FOREIGN_KEY_CHECKS=0"],
      "postSQL": [
        "UPDATE challenges c LEFT JOIN dynamic_challenge dc ON c.id = dc.id SET c.initial = dc.dynamic_initial, c.minimum = dc.dynamic_minimum, c.decay = dc.dynamic_decay, c.function = dc.dynamic_function WHERE dc.id IS NOT NULL",

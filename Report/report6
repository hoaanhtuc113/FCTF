a, Java Tomcat
TEMPLATE
Tomcat requires three writable directories: logs, work, temp. These directories must be symlinked to /tmp. WAR files should also be extracted during build time to avoid runtime writes.
# <TOMCAT_VER> example: 10.1.40   |   <JDK_VER> example: 17
FROM tomcat:<TOMCAT_VER>-jdk<JDK_VER>

# Redirect Tomcat writable directories to /tmp
RUN rm -rf /usr/local/tomcat/logs && ln -s /tmp/tomcat-logs /usr/local/tomcat/logs && \
    rm -rf /usr/local/tomcat/work && ln -s /tmp/tomcat-work /usr/local/tomcat/work && \
    rm -rf /usr/local/tomcat/temp && ln -s /tmp/tomcat-temp /usr/local/tomcat/temp

# Remove default applications
RUN rm -rf /usr/local/tomcat/webapps/*

# Copy and extract WAR during build time
COPY <APP_NAME>.war /tmp/app.war
RUN mkdir -p /usr/local/tomcat/webapps/<CONTEXT> && \
    cd /usr/local/tomcat/webapps/<CONTEXT> && \
    jar xf /tmp/app.war && \
    rm /tmp/app.war

# Change the server port
RUN sed -i 's/port="8080"/port="<PORT>"/' /usr/local/tomcat/conf/server.xml

ENV CATALINA_OUT=/dev/stdout
ENV CATALINA_TMPDIR=/tmp/tomcat-temp

RUN chown -R 1000:1000 /usr/local/tomcat

USER 1000

EXPOSE <PORT>

CMD ["sh","-c","mkdir -p /tmp/tomcat-logs /tmp/tomcat-work /tmp/tomcat-temp && exec catalina.sh run -Djava.io.tmpdir=/tmp/tomcat-temp -Dcatalina.base=/usr/local/tomcat"]


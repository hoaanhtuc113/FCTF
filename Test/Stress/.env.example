# Stress Tests Configuration
# Copy this file to .env and update with your values

# API Base URL (required)
BASE_URL=https://apicontestant.sanchoi.iahn.hanoi.vn 

# Authentication credentials (required)
USERNAME=user1
PASSWORD=1

# Or use existing token (optional - if provided, login will be skipped)
# TOKEN=your_jwt_token

# Test type (optional, default: load)
# Options: smoke, load, spike, stress, soak
TEST_TYPE=spike

# Additional parameters (optional)
TOP_COUNT=10

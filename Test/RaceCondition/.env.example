# k6 environment variables
# Fill in required values for the scenario you run.

BASE_URL=https://api3.fctf.site
# USERNAME=user1
# PASSWORD=1
TOKEN=
TOKEN_FILE=tokens.txt
CONCURRENCY=10
STRICT=true

CHALLENGE_ID=3
CHALLENGE_FLAG=a
WRONG_FLAG=123

# Challenge start/stop race tests
START_CHALLENGE_ID=2
STOP_CHALLENGE_ID=2
START_BEFORE_STOP=true
START_WAIT_SECONDS=2
USE_TOKEN_LIST=true
CHALLENGE_ID_LIST=
EXPECT_LIMIT=false
EXPECT_MAX_START=0

# Max attempts race test
MAX_ATTEMPTS_CHALLENGE_ID=167
MAX_ATTEMPTS=5
USE_TOKEN_LIST=true

HINT_ID=8
HINT_TYPE=hints

CHALLENGE_CATEGORY=Web
DYN_FUNCTION=logarithmic
DYN_INITIAL=100
DYN_DECAY=5
DYN_MINIMUM=20
DYN_EXPECTED_SOLVE_COUNT=10
DYN_POLL_ATTEMPTS=10
DYN_POLL_DELAY_MS=500

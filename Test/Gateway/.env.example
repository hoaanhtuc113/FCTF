# Gateway under test
GATEWAY_BASE_URL=http://localhost:8080
PROTECTED_PATH=/anything/fctf-gateway
AUTH_COOKIE_NAME=FCTF_Auth_Token

# Optional echo validation (set true if your upstream echoes request body)
ASSERT_ECHO=false

# Token inputs (choose one approach)
# 1) Direct token values:
# VALID_TOKEN=
# EXPIRED_TOKEN=
# INVALID_TOKEN=invalid.token

# 2) Auto-generate VALID_TOKEN + EXPIRED_TOKEN from PRIVATE_KEY + CHALLENGE_ROUTE
PRIVATE_KEY=
CHALLENGE_ROUTE=httpbin.org:80
BROKEN_ROUTE=127.0.0.1:1

# Optional alternate route for manual checks
ALT_CHALLENGE_ROUTE=example.org:80

# Load-test settings (gateway_passthrough_load.js)
DURATION=2m
REQUEST_RATE=50
PRE_ALLOCATED_VUS=30
MAX_VUS=120

# Spike-test settings (gateway_spike.js)
SPIKE_WARM_VUS=20
SPIKE_PEAK_VUS=200

# Soak-test settings (gateway_soak.js)
SOAK_VUS=30
SOAK_DURATION=30m
SOAK_THINK_TIME_MS=150

# Rate-limit test settings (gateway_rate_limit.js)
RATE_LIMIT_VUS=200
RATE_LIMIT_DURATION=20s
MIN_429_RATIO=0.05

# Body-limit test settings (gateway_body_limits.js)
HTTP_MAX_BODY_BYTES_EXPECTED=10485760
SMALL_BODY_BYTES=2048
BIG_BODY_BYTES=10486784

# Integration echo strictness
STRICT_ECHO=false

# TCP gateway smoke settings
TCP_GATEWAY_HOST=localhost
TCP_GATEWAY_PORT=1337

# TCP limit test settings (gateway_tcp_limits.ps1)
TCP_LIMIT_CONNECTIONS=30
TCP_LIMIT_HOLD_MS=3000

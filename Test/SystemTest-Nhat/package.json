{
    "name": "systemtest-nhat",
    "version": "1.0.0",
    "description": "Playwright system test suite for FCTF admin flows",
    "scripts": {
        "test": "node run-ordered-tests.js",
        "test:headed": "node run-ordered-tests.js --headed",
        "test:uc03": "playwright test tests/uc03-create-challenge-test.spec.ts --config playwright.config.ts",
        "test:uc03:headed": "playwright test tests/uc03-create-challenge-test.spec.ts --config playwright.config.ts --headed",
        "test:report": "playwright show-report playwright-report --port=0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2"
    }
}